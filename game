<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>God Simulator VR - Omnipotence Edition</title>
    <meta name="description" content="A Massive God Simulator in VR using A-Frame">
    <!-- A-Frame and Essential Extensions -->
    <script src="https://aframe.io/releases/1.4.2/aframe.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/c-frame/aframe-extras@7.0.0/dist/aframe-extras.min.js"></script>
    <script src="https://unpkg.com/aframe-environment-component@1.3.2/dist/aframe-environment-component.min.js"></script>
    
    <script>
      /**
       * CONSTANTS & CONFIGURATION
       * Defining the boundaries of the universe.
       */
      const WORLD_RADIUS = 4.5;
      const MAX_MANA = 500;
      const ERAS = ['Primitive', 'Stone', 'Bronze', 'Iron', 'Imperial', 'Celestial'];
      
      /**
       * SYSTEM: GOD ENGINE OMNI
       * The core orchestration engine for the simulation.
       * Manages global variables, time-cycles, civilization stats, and game loops.
       */
      AFRAME.registerSystem('god-engine', {
        init: function () {
          // Resources
          this.mana = 100;
          this.faith = 0;
          this.wood = 0;
          this.stone = 0;
          this.population = 0;
          
          // Progression
          this.xp = 0;
          this.level = 1;
          this.eraIndex = 0;
          this.questIndex = 0;
          
          // World State
          this.timeScale = 1;
          this.isDay = true;
          this.weather = 'clear'; // clear, rain, storm
          this.happiness = 100;
          
          this.quests = [
            { t: "Genesis", d: "Spawn 5 followers to begin your realm.", goal: 5, type: 'pop' },
            { t: "The First Grove", d: "Grow 10 trees with Life Rain.", goal: 10, type: 'trees' },
            { t: "Shelter", d: "Ensure villagers build 3 huts through happiness.", goal: 3, type: 'huts' },
            { t: "Sacred Pilgrimage", d: "Drop 5 followers at the Temple.", goal: 5, type: 'temple' },
            { t: "Industrial Era", d: "Collect 100 Wood and 50 Stone.", goal: 100, type: 'resources' },
            { t: "Ascension", d: "Reach the Celestial Era.", goal: 5, type: 'era' }
          ];

          // Start the Heartbeat of the Universe
          this.startLoops();
        },

        startLoops: function() {
          // Game Tick (Physics and Stats) - 1s
          setInterval(() => this.tickWorld(), 1000);
          // Resource Generation - 3s
          setInterval(() => this.generateResources(), 3000);
          // Mana Regeneration - 0.5s
          setInterval(() => {
            this.mana = Math.min(MAX_MANA, this.mana + (0.5 * this.level));
            this.updateHUD();
          }, 500);
        },

        tickWorld: function() {
          this.updateHappiness();
          this.checkQuests();
          this.updateHUD();
        },

        updateHappiness: function() {
          const trees = document.querySelectorAll('.tree').length;
          const huts = document.querySelectorAll('.hut').length;
          // Happiness calculation logic
          let base = 50;
          let treeBonus = (trees / (this.population || 1)) * 20;
          let shelterBonus = (huts / (this.population || 1)) * 30;
          this.happiness = Math.max(0, Math.min(100, base + treeBonus + shelterBonus));
        },

        generateResources: function() {
          if (this.population <= 0) return;
          // Active workers find resources
          const workers = document.querySelectorAll('.villager');
          workers.forEach(w => {
            if (Math.random() > 0.7) {
              this.wood += Math.floor(Math.random() * 2);
              this.faith += 1;
            }
          });
        },

        checkQuests: function() {
          const q = this.quests[this.questIndex];
          if (!q) return;

          let current = 0;
          switch(q.type) {
            case 'pop': current = this.population; break;
            case 'trees': current = document.querySelectorAll('.tree').length; break;
            case 'huts': current = document.querySelectorAll('.hut').length; break;
            case 'resources': current = this.wood; break;
          }

          if (current >= q.goal) {
            this.completeQuest();
          }
        },

        completeQuest: function() {
          this.gainXP(50);
          this.questIndex = Math.min(this.questIndex + 1, this.quests.length - 1);
          this.triggerVisualFeedback('#00ff00');
        },

        gainXP: function(amt) {
          this.xp += amt;
          if (this.xp >= 100) {
            this.xp -= 100;
            this.level++;
            if (this.level % 2 === 0) this.advanceEra();
          }
        },

        advanceEra: function() {
          this.eraIndex = Math.min(this.eraIndex + 1, ERAS.length - 1);
          // Evolution VFX
          this.triggerVisualFeedback('#fff');
        },

        triggerVisualFeedback: function(color) {
          const p = document.querySelector('#planet');
          p.setAttribute('animation__flash', `property: material.emissive; from: ${color}; to: #000; dur: 2000`);
          p.setAttribute('animation__glow', `property: material.emissiveIntensity; from: 2; to: 0; dur: 2000`);
        },

        updateHUD: function() {
          const s = document.querySelector('#stats-bar');
          if (s) s.setAttribute('value', `ERA: ${ERAS[this.eraIndex]} | LEVEL: ${this.level} | POP: ${this.population} | FAITH: ${Math.floor(this.faith)}`);
          
          const r = document.querySelector('#resource-bar');
          if (r) r.setAttribute('value', `WOOD: ${this.wood} | STONE: ${this.stone} | HAPPY: ${Math.floor(this.happiness)}%`);
          
          const qT = document.querySelector('#quest-title');
          const qD = document.querySelector('#quest-desc');
          if (qT) qT.setAttribute('value', this.quests[this.questIndex].t);
          if (qD) qD.setAttribute('value', this.quests[this.questIndex].d);

          const manaBar = document.querySelector('#mana-fill');
          if (manaBar) manaBar.setAttribute('scale', `${this.mana / MAX_MANA} 1 1`);
        }
      });

      /**
       * COMPONENT: VILLAGER ADVANCED AI
       * Logic for individual agents: hunger, life-cycles, social, and building.
       */
      AFRAME.registerComponent('villager-ai', {
        schema: {
          type: { default: 'citizen' }
        },

        init: function () {
          this.age = 0;
          this.health = 100;
          this.state = 'idle'; // idle, walking, social, building, resource
          this.speed = 0.015;
          this.targetPos = new THREE.Vector3();
          this.walkCycle = 0;
          this.isBuilding = false;
          
          this.el.setAttribute('scale', '0.2 0.2 0.2');
          this.pickNewTarget();
        },

        pickNewTarget: function() {
          // Wander within world radius
          const angle = Math.random() * Math.PI * 2;
          const r = Math.random() * (WORLD_RADIUS - 0.5);
          this.targetPos.set(Math.cos(angle) * r, 0.1, Math.sin(angle) * r);
          this.state = 'walking';
          
          // Randomly decide to social or build instead of walk
          if (Math.random() > 0.85) this.state = 'social';
        },

        tick: function (time, deltaTime) {
          if (this.el.is('grabbed')) return;

          this.age += deltaTime / 1000;
          
          // Lifespan Logic: Aging through 3 scales
          if (this.age < 20) this.el.setAttribute('scale', '0.2 0.2 0.2');
          else if (this.age < 100) this.el.setAttribute('scale', '0.5 0.5 0.5');
          else this.ascend();

          if (this.state === 'walking') {
            this.moveTowardsTarget(deltaTime);
          } else if (this.state === 'social') {
            this.doSocialAction();
          }

          // Check for Auto-Build Hut
          const sys = this.el.sceneEl.systems['god-engine'];
          if (sys.happiness > 80 && !this.isBuilding && sys.wood > 20 && Math.random() < 0.0001) {
            this.constructHut();
          }
        },

        moveTowardsTarget: function(dt) {
          const currentPos = this.el.getAttribute('position');
          const dir = new THREE.Vector3().subVectors(this.targetPos, currentPos).normalize();
          const dist = new THREE.Vector3().subVectors(this.targetPos, currentPos).length();

          if (dist < 0.1) {
            this.state = 'idle';
            setTimeout(() => this.pickNewTarget(), 2000 + Math.random() * 3000);
            return;
          }

          currentPos.x += dir.x * this.speed;
          currentPos.z += dir.z * this.speed;
          
          // Bobbing walk animation
          this.walkCycle += dt * 0.006;
          currentPos.y = 0.1 + Math.abs(Math.sin(this.walkCycle)) * 0.1;
          
          this.el.setAttribute('position', currentPos);
          
          // Rotation
          const angle = Math.atan2(dir.x, dir.z) * 180 / Math.PI;
          this.el.setAttribute('rotation', {y: angle});
        },

        doSocialAction: function() {
          // Simple emoji-like interaction would go here
          this.state = 'idle';
          setTimeout(() => this.pickNewTarget(), 1000);
        },

        constructHut: function() {
          this.isBuilding = true;
          const sys = this.el.sceneEl.systems['god-engine'];
          sys.wood -= 20;
          
          const pos = this.el.getAttribute('position');
          const hut = document.createElement('a-entity');
          hut.classList.add('hut');
          hut.setAttribute('position', `${pos.x} 0.05 ${pos.z}`);
          hut.innerHTML = `
            <a-box color="#8B4513" width="0.4" height="0.3" depth="0.4" position="0 0.15 0"></a-box>
            <a-cone color="#A52A2A" radius-bottom="0.3" height="0.3" position="0 0.4 0" segments-radial="4"></a-cone>
          `;
          hut.setAttribute('animation', 'property: scale; from: 0 0 0; to: 1 1 1; dur: 3000');
          document.querySelector('#world-container').appendChild(hut);
          
          setTimeout(() => { this.isBuilding = false; }, 5000);
        },

        ascend: function() {
          const sys = this.el.sceneEl.systems['god-engine'];
          sys.population--;
          sys.gainXP(20);
          sys.faith += 50;

          // Particle burst
          const p = document.createElement('a-entity');
          p.setAttribute('position', this.el.getAttribute('position'));
          p.innerHTML = `<a-sphere radius="0.1" color="gold" material="emissive:gold" animation="property: position; to: 0 20 0; dur: 4000"></a-sphere>`;
          this.el.sceneEl.appendChild(p);

          this.el.parentNode.removeChild(this.el);
        }
      });

      /**
       * COMPONENT: GOD CONTROLS PRO
       * Physics-based interaction and miracle casting.
       */
      AFRAME.registerComponent('god-controls', {
        init: function () {
          this.currentPower = 'life'; // life, storm, shield, time
          this.heldEntity = null;
          
          this.el.addEventListener('abuttondown', () => this.spawnVillager());
          this.el.addEventListener('bbuttondown', () => this.executePower());
          this.el.addEventListener('xbuttondown', () => this.cyclePower());
          
          this.el.addEventListener('triggerdown', () => this.grabStart());
          this.el.addEventListener('triggerup', () => this.grabEnd());

          // For Velocity Tracking
          this.lastHandPos = new THREE.Vector3();
          this.handVelocity = new THREE.Vector3();
        },

        cyclePower: function() {
          const powers = ['life', 'storm', 'shield'];
          const idx = (powers.indexOf(this.currentPower) + 1) % powers.length;
          this.currentPower = powers[idx];
          
          const indicator = document.querySelector('#power-text');
          const colors = { life: '#2ecc71', storm: '#3498db', shield: '#f1c40f' };
          indicator.setAttribute('value', `POWER: ${this.currentPower.toUpperCase()}`);
          indicator.setAttribute('color', colors[this.currentPower]);
        },

        grabStart: function() {
          const vills = document.querySelectorAll('.villager');
          const handPos = new THREE.Vector3();
          this.el.object3D.getWorldPosition(handPos);
          
          let closest = null;
          let minDist = 0.6;
          vills.forEach(v => {
            let vPos = new THREE.Vector3();
            v.object3D.getWorldPosition(vPos);
            let d = handPos.distanceTo(vPos);
            if (d < minDist) { minDist = d; closest = v; }
          });

          if (closest) {
            this.heldEntity = closest;
            this.heldEntity.addState('grabbed');
          }
        },

        grabEnd: function() {
          if (this.heldEntity) {
            this.heldEntity.removeState('grabbed');
            
            // Check for Temple Drop
            const pos = this.heldEntity.getAttribute('position');
            const sys = this.el.sceneEl.systems['god-engine'];
            if (pos.x < -2 && pos.z < -2 && sys.questIndex === 3) {
              sys.gainXP(20);
            }

            // Apply "Throw" Velocity
            this.heldEntity.setAttribute('animation__throw', {
              property: 'position',
              to: `${pos.x + this.handVelocity.x * 20} 0.1 ${pos.z + this.handVelocity.z * 20}`,
              dur: 1000,
              easing: 'easeOutQuad'
            });

            this.heldEntity = null;
          }
        },

        tick: function(t, dt) {
          // Track Hand Velocity
          const currentHandPos = new THREE.Vector3();
          this.el.object3D.getWorldPosition(currentHandPos);
          this.handVelocity.subVectors(currentHandPos, this.lastHandPos).divideScalar(dt / 1000);
          this.lastHandPos.copy(currentHandPos);

          if (this.heldEntity) {
            this.heldEntity.setAttribute('position', {
              x: currentHandPos.x,
              y: currentHandPos.y - 0.2,
              z: currentHandPos.z
            });
          }
        },

        spawnVillager: function() {
          const sys = this.el.sceneEl.systems['god-engine'];
          if (sys.mana < 30) return;
          sys.mana -= 30;
          sys.population++;

          const v = document.createElement('a-entity');
          v.classList.add('villager');
          v.setAttribute('villager-ai', '');
          v.setAttribute('position', `${(Math.random()-0.5)*2} 0.5 ${(Math.random()-0.5)*2 - 2}`);
          
          // Visual Mesh
          const mesh = document.createElement('a-entity');
          mesh.classList.add('body-mesh');
          mesh.innerHTML = `
            <a-box width="0.2" height="0.4" depth="0.2" color="#3498db" material="roughness: 1"></a-box>
            <a-sphere radius="0.15" position="0 0.3 0" color="#ffdbac"></a-sphere>
            <a-box width="0.25" height="0.1" depth="0.25" position="0 0.45 0" color="#2c3e50"></a-box>
          `;
          v.appendChild(mesh);
          document.querySelector('a-scene').appendChild(v);
        },

        executePower: function() {
          const sys = this.el.sceneEl.systems['god-engine'];
          if (sys.mana < 50) return;
          sys.mana -= 50;

          switch(this.currentPower) {
            case 'life': this.castLifeRain(); break;
            case 'storm': this.castLightning(); break;
            case 'shield': this.castProtection(); break;
          }
        },

        castLifeRain: function() {
          // FX
          const rain = document.createElement('a-entity');
          rain.setAttribute('particle-system', 'preset: rain; color: #3498db; particleCount: 500');
          rain.setAttribute('position', '0 3 -2');
          document.querySelector('a-scene').appendChild(rain);
          setTimeout(() => rain.parentNode.removeChild(rain), 3000);

          // Growth
          for(let i=0; i<3; i++) {
            const tree = document.createElement('a-entity');
            tree.classList.add('tree');
            const x = (Math.random()-0.5) * (WORLD_RADIUS * 2);
            const z = (Math.random()-0.5) * (WORLD_RADIUS * 2) - 2;
            tree.setAttribute('position', `${x} 0.05 ${z}`);
            tree.innerHTML = `
              <a-cylinder radius="0.05" height="0.4" color="#5d4037" position="0 0.2 0"></a-cylinder>
              <a-sphere radius="0.3" color="#2ecc71" position="0 0.6 0" animation="property:scale; from:0 0 0; to:1 1 1; dur:2000"></a-sphere>
            `;
            document.querySelector('#world-container').appendChild(tree);
          }
          this.el.sceneEl.systems['god-engine'].triggerVisualFeedback('#2ecc71');
        },

        castLightning: function() {
          // Storm FX would clear unwanted debris or speed up resources
          this.el.sceneEl.systems['god-engine'].triggerVisualFeedback('#3498db');
        },

        castProtection: function() {
          // Boost happiness and stop death for a while
          this.el.sceneEl.systems['god-engine'].happiness = 100;
          this.el.sceneEl.systems['god-engine'].triggerVisualFeedback('#f1c40f');
        }
      });
    </script>
  </head>
  <body>
    <!-- A-Scene: The Container of Reality -->
    <a-scene god-engine fog="type: exponential; color: #080810; density: 0.025">
      
      <!-- ASSETS -->
      <a-assets>
        <img id="sky" src="https://cdn.aframe.io/a-painter/images/sky.jpg">
      </a-assets>

      <!-- ENVIRONMENT -->
      <a-entity environment="preset: starry; ground: hills; groundColor: #020202; grid: none; dressing: arches; dressingAmount: 6; dressingColor: #1a1a1a"></a-entity>

      <!-- THE WORLD DISC (THE REALM) -->
      <a-entity id="world-container" position="0 0.8 -2.5">
        <!-- Main Planet Mesh -->
        <a-cylinder id="planet" radius="4.5" height="0.2" color="#111" material="roughness: 0.9; metalness: 0.1">
          <!-- Bioluminescent Atmosphere -->
          <a-ring color="#3498db" radius-inner="4.48" radius-outer="4.55" rotation="-90 0 0" position="0 0.11 0" opacity="0.6" animation="property: opacity; from: 0.3; to: 0.8; dur: 4000; loop: true; dir: alternate"></a-ring>
        </a-cylinder>

        <!-- The Grand Temple of the Celestials -->
        <a-entity id="temple-zone" position="-3 0.1 -3">
          <a-torus radius="1.2" radius-tubular="0.03" color="#f1c40f" rotation="90 0 0" animation="property: rotation; to: 90 360 0; dur: 8000; loop: true; easing: linear"></a-torus>
          <a-cylinder radius="0.8" height="0.1" color="#222"></a-cylinder>
          <a-text value="CELESTIAL NEXUS" align="center" position="0 2 0" scale="0.8" color="#f1c40f" font="exo2bold"></a-text>
          <a-light type="point" color="#f1c40f" intensity="1.2" distance="5"></a-light>
          
          <!-- Inner Eternal Flame -->
          <a-sphere radius="0.1" position="0 0.5 0" color="#fff" material="emissive: #fff; emissiveIntensity: 5"></a-sphere>
        </a-entity>
      </a-entity>

      <!-- GOD INTERFACE (THE DIVINE HUD) -->
      <a-entity id="hud-anchor" position="0 2.2 -3.5">
        <a-plane width="4" height="1.8" color="#000" material="opacity: 0.92; transparent: true; blending: additive; side: double">
          <!-- Top Bar: Civilization Stats -->
          <a-text id="stats-bar" value="ERA: PRIMITIVE | LEVEL: 1 | POP: 0 | FAITH: 100" align="center" position="0 0.7 0.05" scale="0.5" color="#3498db" font="mozillavr"></a-text>
          
          <!-- Mid Panel: Active Quest -->
          <a-text id="quest-title" value="GENESIS" align="center" position="0 0.3 0.05" scale="1.2" font="kelsonsans" color="#fff"></a-text>
          <a-text id="quest-desc" value="Spawn 5 followers to begin your realm." align="center" position="0 0.05 0.05" scale="0.5" color="#bdc3c7"></a-text>
          
          <!-- Resource Panel -->
          <a-text id="resource-bar" value="WOOD: 0 | STONE: 0 | HAPPY: 100%" align="center" position="0 -0.25 0.05" scale="0.45" color="#2ecc71"></a-text>

          <!-- Mana Gauge -->
          <a-entity position="0 -0.55 0.05">
             <a-plane width="3" height="0.12" color="#222"></a-plane>
             <a-plane id="mana-fill" width="3" height="0.12" color="#3498db" position="0 0 0.01" pivot="-1.5 0 0"></a-plane>
             <a-text value="DIVINE ENERGY (MANA)" position="-1.5 0.2 0" scale="0.35" color="#3498db"></a-text>
          </a-entity>

          <!-- Control Guide -->
          <a-text id="power-text" value="POWER: LIFE" align="center" position="0 -0.75 0.05" scale="0.4" color="#2ecc71"></a-text>
          <a-text value="[A] Spawn | [B] Miracle | [X] Cycle Powers | [Trigger] Grab & Throw" align="center" position="0 -0.85 0.05" scale="0.25" color="#7f8c8d"></a-text>
        </a-plane>
      </a-entity>

      <!-- GOD'S PRESENCE (CONTROLS) -->
      <a-entity id="rig">
        <a-camera position="0 1.6 0"></a-camera>
        <a-entity oculus-touch-controls="hand: left" laser-controls="hand: left" raycaster="objects: .none"></a-entity>
        <a-entity oculus-touch-controls="hand: right" god-controls>
           <!-- Hand Visualizer -->
           <a-sphere radius="0.05" color="#fff" material="emissive: #3498db; emissiveIntensity: 3"></a-sphere>
           <a-light type="point" color="#3498db" intensity="1.5" distance="2.5"></a-light>
           
           <!-- Power Particle Ring -->
           <a-ring radius-inner="0.08" radius-outer="0.1" color="#3498db" opacity="0.5" rotation="90 0 0"></a-ring>
        </a-entity>
      </a-entity>

      <!-- LIGHTING -->
      <a-light id="sun" type="directional" position="5 15 5" intensity="1" color="#fff"></a-light>
      <a-light type="ambient" color="#1a1a20"></a-light>
      <a-light type="point" position="-5 5 -5" intensity="0.5" color="#3498db"></a-light>

    </a-scene>
  </body>
</html>
